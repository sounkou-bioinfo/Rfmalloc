diff --git a/R/fmalloc_linalg.R b/R/fmalloc_linalg.R
new file mode 100644
index 0000000..e612891
--- /dev/null
+++ b/R/fmalloc_linalg.R
@@ -0,0 +1,340 @@
+#' Matrix algebra for fmalloc-backed vectors and matrices
+#'
+#' Provides fmalloc-aware matrix products for `%*%`, `crossprod()`, and
+#' `tcrossprod()`. Results are allocated in the runtime of the first fmalloc
+#' operand and returned as fmalloc-backed matrices.
+#'
+#' These methods intentionally use direct element access rather than falling back
+#' through `base::%*%`, so large results do not have to be materialized as
+#' ordinary R matrices before being copied back into fmalloc storage.
+#'
+#' @param x,y Numeric, logical, or complex vectors/matrices. At least one
+#'   operand must be fmalloc-backed for these methods to dispatch.
+#' @param ... Unused.
+#'
+#' @return An fmalloc-backed numeric or complex matrix.
+#'
+#' @name fmalloc_linalg
+NULL
+
+.fmalloc_linalg_strip_operand <- function(x, arg_name) {
+    x <- .fmalloc_strip_class(x)
+
+    if (!(is.numeric(x) || is.logical(x) || is.complex(x))) {
+        stop(sprintf("%s must be a numeric, logical, or complex vector/matrix", arg_name))
+    }
+
+    dim_x <- dim(x)
+    if (!is.null(dim_x) && length(dim_x) != 2L) {
+        stop(sprintf("%s must be a vector or a two-dimensional matrix", arg_name))
+    }
+
+    x
+}
+
+.fmalloc_linalg_runtime <- function(x, y = NULL) {
+    if (inherits(x, "fmalloc")) {
+        return(.fmalloc_runtime_for_vector(x))
+    }
+    if (!is.null(y) && inherits(y, "fmalloc")) {
+        return(.fmalloc_runtime_for_vector(y))
+    }
+
+    stop("at least one operand must be fmalloc-backed")
+}
+
+.fmalloc_linalg_result_type <- function(x, y = NULL) {
+    if (is.complex(x) || (!is.null(y) && is.complex(y))) {
+        "complex"
+    } else {
+        "numeric"
+    }
+}
+
+.fmalloc_linalg_check_output_dims <- function(nrow, ncol) {
+    dims <- c(as.double(nrow), as.double(ncol))
+    if (any(!is.finite(dims)) || any(is.na(dims)) || any(dims < 0) ||
+        any(dims != floor(dims))) {
+        stop("matrix product dimensions must be finite non-negative integers")
+    }
+    if (any(dims > .Machine$integer.max)) {
+        stop("matrix product dimensions exceed R's matrix dimension limit")
+    }
+
+    as.integer(dims)
+}
+
+.fmalloc_linalg_allocate_matrix <- function(type, nrow, ncol, runtime, dimnames = NULL) {
+    dims <- .fmalloc_linalg_check_output_dims(nrow, ncol)
+    length <- as.double(dims[[1L]]) * as.double(dims[[2L]])
+
+    ans <- create_fmalloc_vector(type = type, length = length, runtime = runtime)
+    dim(ans) <- dims
+    if (!is.null(dimnames)) {
+        dimnames(ans) <- dimnames
+    }
+
+    .fmalloc_apply_class(ans, type = type, shape = "matrix")
+}
+
+.fmalloc_linalg_shape_matrix <- function(x) {
+    dim_x <- dim(x)
+    if (is.null(dim_x)) {
+        list(nrow = as.double(length(x)), ncol = 1, kind = "column", has_dim = FALSE)
+    } else {
+        list(nrow = as.double(dim_x[[1L]]), ncol = as.double(dim_x[[2L]]),
+             kind = "matrix", has_dim = TRUE)
+    }
+}
+
+.fmalloc_linalg_get <- function(x, shape, i, j) {
+    idx <- switch(shape$kind,
+        "matrix" = i + (j - 1) * shape$nrow,
+        "row" = j,
+        "column" = i,
+        stop("invalid fmalloc matrix shape")
+    )
+
+    x[[idx]]
+}
+
+.fmalloc_linalg_dimnames <- function(x, margin) {
+    if (is.null(dim(x))) {
+        return(NULL)
+    }
+    dn <- dimnames(x)
+    if (is.null(dn) || length(dn) < margin) {
+        return(NULL)
+    }
+    dn[[margin]]
+}
+
+.fmalloc_linalg_result_dimnames <- function(first, second) {
+    if (is.null(first) && is.null(second)) {
+        NULL
+    } else {
+        list(first, second)
+    }
+}
+
+.fmalloc_matmul_shapes <- function(x, y) {
+    dim_x <- dim(x)
+    dim_y <- dim(y)
+    len_x <- as.double(length(x))
+    len_y <- as.double(length(y))
+
+    if (is.null(dim_x) && is.null(dim_y)) {
+        if (len_x != len_y) {
+            stop("non-conformable arguments")
+        }
+        return(list(
+            x = list(nrow = 1, ncol = len_x, kind = "row", has_dim = FALSE),
+            y = list(nrow = len_y, ncol = 1, kind = "column", has_dim = FALSE)
+        ))
+    }
+
+    if (is.null(dim_x)) {
+        y_shape <- .fmalloc_linalg_shape_matrix(y)
+        if (len_x == y_shape$nrow) {
+            x_shape <- list(nrow = 1, ncol = len_x, kind = "row", has_dim = FALSE)
+        } else if (y_shape$nrow == 1) {
+            x_shape <- list(nrow = len_x, ncol = 1, kind = "column", has_dim = FALSE)
+        } else {
+            stop("non-conformable arguments")
+        }
+        return(list(x = x_shape, y = y_shape))
+    }
+
+    if (is.null(dim_y)) {
+        x_shape <- .fmalloc_linalg_shape_matrix(x)
+        if (len_y == x_shape$ncol) {
+            y_shape <- list(nrow = len_y, ncol = 1, kind = "column", has_dim = FALSE)
+        } else if (x_shape$ncol == 1) {
+            y_shape <- list(nrow = 1, ncol = len_y, kind = "row", has_dim = FALSE)
+        } else {
+            stop("non-conformable arguments")
+        }
+        return(list(x = x_shape, y = y_shape))
+    }
+
+    x_shape <- .fmalloc_linalg_shape_matrix(x)
+    y_shape <- .fmalloc_linalg_shape_matrix(y)
+    if (x_shape$ncol != y_shape$nrow) {
+        stop("non-conformable arguments")
+    }
+
+    list(x = x_shape, y = y_shape)
+}
+
+.fmalloc_matmul <- function(x, y) {
+    runtime <- .fmalloc_linalg_runtime(x, y)
+
+    x0 <- .fmalloc_linalg_strip_operand(x, "x")
+    y0 <- .fmalloc_linalg_strip_operand(y, "y")
+    shapes <- .fmalloc_matmul_shapes(x0, y0)
+    x_shape <- shapes$x
+    y_shape <- shapes$y
+
+    out_type <- .fmalloc_linalg_result_type(x0, y0)
+    dimnames <- .fmalloc_linalg_result_dimnames(
+        .fmalloc_linalg_dimnames(x0, 1L),
+        .fmalloc_linalg_dimnames(y0, 2L)
+    )
+
+    ans <- .fmalloc_linalg_allocate_matrix(out_type, x_shape$nrow, y_shape$ncol,
+                                           runtime, dimnames = dimnames)
+
+    j <- 1
+    while (j <= y_shape$ncol) {
+        i <- 1
+        while (i <= x_shape$nrow) {
+            acc <- if (out_type == "complex") 0 + 0i else 0
+            k <- 1
+            while (k <= x_shape$ncol) {
+                acc <- acc +
+                    .fmalloc_linalg_get(x0, x_shape, i, k) *
+                    .fmalloc_linalg_get(y0, y_shape, k, j)
+                k <- k + 1
+            }
+            ans[[i + (j - 1) * x_shape$nrow]] <- acc
+            i <- i + 1
+        }
+        j <- j + 1
+    }
+
+    ans
+}
+
+.fmalloc_crossprod_impl <- function(x, y = NULL) {
+    runtime <- .fmalloc_linalg_runtime(x, y)
+
+    x0 <- .fmalloc_linalg_strip_operand(x, "x")
+    y0 <- if (is.null(y)) x0 else .fmalloc_linalg_strip_operand(y, "y")
+
+    x_shape <- .fmalloc_linalg_shape_matrix(x0)
+    y_shape <- .fmalloc_linalg_shape_matrix(y0)
+    if (x_shape$nrow != y_shape$nrow) {
+        stop("non-conformable arguments")
+    }
+
+    out_type <- .fmalloc_linalg_result_type(x0, y0)
+    dimnames <- .fmalloc_linalg_result_dimnames(
+        .fmalloc_linalg_dimnames(x0, 2L),
+        .fmalloc_linalg_dimnames(y0, 2L)
+    )
+
+    ans <- .fmalloc_linalg_allocate_matrix(out_type, x_shape$ncol, y_shape$ncol,
+                                           runtime, dimnames = dimnames)
+
+    j <- 1
+    while (j <= y_shape$ncol) {
+        i <- 1
+        while (i <= x_shape$ncol) {
+            acc <- if (out_type == "complex") 0 + 0i else 0
+            k <- 1
+            while (k <= x_shape$nrow) {
+                acc <- acc +
+                    .fmalloc_linalg_get(x0, x_shape, k, i) *
+                    .fmalloc_linalg_get(y0, y_shape, k, j)
+                k <- k + 1
+            }
+            ans[[i + (j - 1) * x_shape$ncol]] <- acc
+            i <- i + 1
+        }
+        j <- j + 1
+    }
+
+    ans
+}
+
+.fmalloc_tcrossprod_impl <- function(x, y = NULL) {
+    runtime <- .fmalloc_linalg_runtime(x, y)
+
+    x0 <- .fmalloc_linalg_strip_operand(x, "x")
+    y0 <- if (is.null(y)) x0 else .fmalloc_linalg_strip_operand(y, "y")
+
+    x_shape <- .fmalloc_linalg_shape_matrix(x0)
+    y_shape <- .fmalloc_linalg_shape_matrix(y0)
+    if (x_shape$ncol != y_shape$ncol) {
+        stop("non-conformable arguments")
+    }
+
+    out_type <- .fmalloc_linalg_result_type(x0, y0)
+    dimnames <- .fmalloc_linalg_result_dimnames(
+        .fmalloc_linalg_dimnames(x0, 1L),
+        .fmalloc_linalg_dimnames(y0, 1L)
+    )
+
+    ans <- .fmalloc_linalg_allocate_matrix(out_type, x_shape$nrow, y_shape$nrow,
+                                           runtime, dimnames = dimnames)
+
+    j <- 1
+    while (j <= y_shape$nrow) {
+        i <- 1
+        while (i <= x_shape$nrow) {
+            acc <- if (out_type == "complex") 0 + 0i else 0
+            k <- 1
+            while (k <= x_shape$ncol) {
+                acc <- acc +
+                    .fmalloc_linalg_get(x0, x_shape, i, k) *
+                    .fmalloc_linalg_get(y0, y_shape, j, k)
+                k <- k + 1
+            }
+            ans[[i + (j - 1) * x_shape$nrow]] <- acc
+            i <- i + 1
+        }
+        j <- j + 1
+    }
+
+    ans
+}
+
+#' @rdname fmalloc_linalg
+#' @method %*% fmalloc
+#' @export
+`%*%.fmalloc` <- function(x, y) {
+    .fmalloc_matmul(x, y)
+}
+
+#' @rdname fmalloc_linalg
+#' @method crossprod fmalloc
+#' @export
+crossprod.fmalloc <- function(x, y = NULL, ...) {
+    if (length(list(...)) != 0L) {
+        stop("unused arguments in fmalloc crossprod method")
+    }
+    .fmalloc_crossprod_impl(x, y)
+}
+
+#' @rdname fmalloc_linalg
+#' @method tcrossprod fmalloc
+#' @export
+tcrossprod.fmalloc <- function(x, y = NULL, ...) {
+    if (length(list(...)) != 0L) {
+        stop("unused arguments in fmalloc tcrossprod method")
+    }
+    .fmalloc_tcrossprod_impl(x, y)
+}
+
+#' @rdname fmalloc_linalg
+#' @method matrixOps fmalloc
+#' @export
+matrixOps.fmalloc <- function(x, y) {
+    if (identical(.Generic, "%*%")) {
+        return(.fmalloc_matmul(x, y))
+    }
+    if (identical(.Generic, "crossprod")) {
+        if (missing(y)) {
+            y <- NULL
+        }
+        return(.fmalloc_crossprod_impl(x, y))
+    }
+    if (identical(.Generic, "tcrossprod")) {
+        if (missing(y)) {
+            y <- NULL
+        }
+        return(.fmalloc_tcrossprod_impl(x, y))
+    }
+
+    stop("Unsupported fmalloc matrixOps generic: ", .Generic)
+}
diff --git a/inst/tinytest/test_fmalloc_linalg.R b/inst/tinytest/test_fmalloc_linalg.R
