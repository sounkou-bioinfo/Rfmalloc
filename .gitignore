# build artifacts (any package)
*.o
*.so
*.tar.gz
*.Rcheck/
packages/*/src/Makevars
packages/*/inst/ggml/libggml.a
.Rhistory
.RData
README.html
packages/*/README.html
README_cache/
packages/*/README_cache/
tools/vendor-ggml/cache/
tools/vendor-pgenlib/cache/
tools/vendor-plink2-import/cache/
tools/vendor-pcaone/cache/
packages/Rpgen/src/libPLINK2.a
packages/Rpgen/src/libPGZSTD.a
packages/Rpgen/src/libPGDEFLATE.a
packages/Rpgen/tools/include/**/*.o
_site/
packages/*/docs/
packages/Rggml/inst/ggml/ggml-vulkan/generated/
packages/Rggml/inst/ggml/ggml-vulkan/vulkan-shaders/vulkan-shaders-gen
packages/*/src/Makevars.win
# RfmallocStatgen ships a static, hand-written Makevars/Makevars.win (it has no
# configure step, unlike Rggml/Rfmalloc whose Makevars are generated), so keep
# them tracked despite the generated-Makevars ignores above.
!packages/RfmallocStatgen/src/Makevars
!packages/RfmallocStatgen/src/Makevars.win
.pi/
.claude/
