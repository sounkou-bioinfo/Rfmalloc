#!/bin/sh
# Windows cleanup (Rtools sh). Mirrors ./cleanup: drop everything the build
# generated, keeping the vendored sources the vendoring recipe owns.
rm -f src/Makevars.win src/*.o src/*.so src/*.dll
rm -f inst/ggml/libggml.a inst/ggml/*.o inst/ggml/ggml-cpu/*.o
rm -rf inst/ggml/ggml-vulkan/generated
rm -f inst/ggml/ggml-vulkan/vulkan-shaders/vulkan-shaders-gen \
      inst/ggml/ggml-vulkan/vulkan-shaders/vulkan-shaders-gen.exe
