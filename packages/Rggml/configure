#!/bin/sh
# Configure script for the Rggml R package.
#
# Builds the vendored GGML CPU backend (inst/ggml/) into a static library
# using R's own toolchain settings, then writes src/Makevars so that the
# package shared object links against it. Mirrors the approach used by
# Rfmalloc's configure (inst/fmalloc/libfmalloc.a) and Rgguf.

set -e

echo "Configuring Rggml..."

# --- Vulkan backend: OPT-IN, never auto-detected ------------------------------
# GGML's Vulkan backend embeds 156 compiled SPIR-V shaders as C++ translation
# units. Generating them takes ~30 s, and the largest (mul_mm, a 141 MB array
# literal) needs ~5 GB of RAM to compile - regardless of -O level, because the
# cost is the compiler parsing the literal, not optimizing it. Auto-enabling
# that on any machine that happens to have glslc installed would be hostile to
# CRAN builders and to ordinary installs, so Vulkan is enabled only on request:
#
#   install.packages("Rggml", configure.args = "--with-vulkan")
#   R CMD INSTALL --configure-args=--with-vulkan .
#   RGGML_VULKAN=1 R CMD INSTALL .
#
# Without it, nothing about the build changes and the CPU/BLAS backends are
# unaffected.
USE_VULKAN="${RGGML_VULKAN:-0}"
USE_CUDA="${RGGML_CUDA:-0}"
CUDA_HOME_REQUEST="${CUDA_HOME:-}"
for _arg in "$@"; do
    case "$_arg" in
        --with-vulkan)    USE_VULKAN=1 ;;
        --without-vulkan) USE_VULKAN=0 ;;
        --with-cuda)      USE_CUDA=1 ;;
        --with-cuda=*)    USE_CUDA=1; CUDA_HOME_REQUEST=${_arg#*=} ;;
        --without-cuda)   USE_CUDA=0 ;;
    esac
done

# --- platform ----------------------------------------------------------------
# R runs configure.win instead of ./configure on Windows; that script re-execs
# this one with RGGML_WINDOWS=1 so the build logic lives in exactly one place.
# uname is the fallback when someone runs ./configure directly under Rtools.
if [ -n "${RGGML_WINDOWS:-}" ]; then
    IS_WIN=1
else
    case `uname -s 2>/dev/null` in
        MINGW*|MSYS*|CYGWIN*) IS_WIN=1 ;;
        *)                    IS_WIN=0 ;;
    esac
fi
[ "$IS_WIN" = "1" ] && echo "Target: Windows (Rtools/MinGW)"

if [ ! -d "inst/ggml" ]; then
    echo "Error: vendored GGML source not found in inst/ggml"
    exit 1
fi

R_HOME=${R_HOME:-$(R RHOME)}
if [ -z "$R_HOME" ]; then
    echo "Error: R_HOME not found. Please install R."
    exit 1
fi
echo "R_HOME: $R_HOME"

CC=`"${R_HOME}/bin/R" CMD config CC`
CXX=`"${R_HOME}/bin/R" CMD config CXX17`
if [ -z "$CXX" ] || [ "$CXX" = "" ]; then
    CXX=`"${R_HOME}/bin/R" CMD config CXX`
fi
AR=`"${R_HOME}/bin/R" CMD config AR`
RANLIB=`"${R_HOME}/bin/R" CMD config RANLIB`
R_CPPFLAGS=`"${R_HOME}/bin/R" CMD config CPPFLAGS`
R_CFLAGS=`"${R_HOME}/bin/R" CMD config CFLAGS`
R_CXXFLAGS=`"${R_HOME}/bin/R" CMD config CXX17FLAGS`
if [ -z "$R_CXXFLAGS" ]; then
    R_CXXFLAGS=`"${R_HOME}/bin/R" CMD config CXXFLAGS`
fi
R_CPICFLAGS=`"${R_HOME}/bin/R" CMD config CPICFLAGS`
R_INCLUDE_FLAGS=`"${R_HOME}/bin/R" CMD config --cppflags`

# AR/RANLIB sometimes come back as "R" (conflicts with the R executable).
case "$AR" in
    "R") AR="ar" ;;
esac
case "$RANLIB" in
    "R") RANLIB="ranlib" ;;
esac

echo "CC: $CC"
echo "CXX: $CXX"
echo "AR: $AR"
echo "RANLIB: $RANLIB"

echo "Building vendored GGML CPU backend (libggml.a)..."
cd inst/ggml || exit 1

export CC CXX AR RANLIB
export CFLAGS="$R_CFLAGS $R_CPICFLAGS"
export CXXFLAGS="$R_CXXFLAGS $R_CPICFLAGS"
export CPPFLAGS="$R_CPPFLAGS"
# Only rggml_io.c needs R's own headers (R.h/Rinternals.h); it is compiled
# with R_GGML_IO_IMPL, which the Makefile pairs with this extra include path.
export R_INCLUDE_FLAGS

# --- Probe runtime-dispatched SIMD variants (RsimdDispatch strategy) ---------
# Per-ISA kernels are compiled here with their own ISA flags, NOT through R's
# recorded package compilation, so R CMD check raises no non-portable-flags
# NOTE. A variant is only linked (and, after a runtime CPUID check, only ever
# called) when the toolchain accepts its flags. Target classification happens
# first, so an Apple clang arm64 build cannot accept and ignore x86 flags.
SIMD_EXTRA_OBJECTS=""
SIMD_DISPATCH_DEFS=""
_probe_base=`mktemp 2>/dev/null || echo "/tmp/rggml_probe_$$"`
_probe_c="${_probe_base}.c"
_probe_macros="${_probe_base}.macros"
printf 'int main(void){return 0;}\n' > "$_probe_c"

# Classify the compiler target from its predefined macros. Testing an ISA flag
# is not target detection: Apple clang accepts -mavx2/-mfma on arm64 and only
# warns that it ignored them, which used to stage an x86 object in an arm build.
if ! $CC -dM -E -x c "$_probe_c" > "$_probe_macros" 2>/dev/null; then
    echo "Error: could not inspect compiler target macros." >&2
    exit 1
fi
IS_X86=0
IS_ARM=0
IS_WASM=0
if grep -Eq '^#define (__wasm__|__EMSCRIPTEN__)( |$)' "$_probe_macros"; then
    IS_WASM=1
elif grep -Eq '^#define (__x86_64__|__i386__|_M_X64|_M_IX86)( |$)' "$_probe_macros"; then
    IS_X86=1
elif grep -Eq '^#define (__aarch64__|_M_ARM64)( |$)' "$_probe_macros"; then
    IS_ARM=1
fi

# x86, including Intel macOS: stage GGML's official AVX2 quant translation
# unit under private symbol names. The exact feature set is runtime-gated
# before the dispatcher can enter it.
X86_SIMD_FLAGS="-msse4.2 -mf16c -mfma -mbmi2 -mavx -mavx2"
if [ "$IS_X86" = "1" ] && \
        $CC $X86_SIMD_FLAGS "$_probe_c" -o "${_probe_c}.out" >/dev/null 2>&1; then
    echo "SIMD: staging GGML's upstream AVX2 Q4_K kernel"
    SIMD_EXTRA_OBJECTS="$SIMD_EXTRA_OBJECTS rggml_x86_avx2.o"
    SIMD_DISPATCH_DEFS="$SIMD_DISPATCH_DEFS -DRGGML_HAVE_X86_AVX2"
fi
# aarch64 (Apple Silicon, ARM Linux/Graviton, Windows-on-ARM): NEON is a
# mandatory baseline, so we compile GGML's own hand-tuned NEON kernels
# unconditionally. They cover every quantized type and supersede the generic
# runtime dispatcher.
GENERIC_DEFS="-DGGML_CPU_GENERIC"
ARCH_OBJECTS=""
ARCH_FLAGS=""
DISPATCH_OBJECTS="cpu_features.o rggml_simd_dispatch.o"
# Recorded into the R-visible binary (see rggml_cpu_info()) so that the branch
# taken here is asserted by the test suite instead of trusted. A silent fallback
# to the generic kernels would otherwise produce an identically green build.
ARCH_KERNELS_DEF=""
SIMD_DISPATCH_DEF="-DRGGML_SIMD_DISPATCH=1"
if [ "$IS_ARM" = "1" ]; then
    if [ ! -f ggml-cpu/arch/arm/quants.c ]; then
        echo "Error: pinned GGML tree is missing its aarch64 quant kernels." >&2
        exit 1
    fi
    echo "SIMD: aarch64 - using GGML's native NEON quant kernels"
    GENERIC_DEFS=""
    ARCH_OBJECTS="ggml-cpu/arch/arm/quants.o"
    DISPATCH_OBJECTS=""
    ARCH_KERNELS_DEF="-DRGGML_ARCH_ARM=1"
    SIMD_DISPATCH_DEF=""
elif [ "$IS_WASM" = "1" ]; then
    if [ ! -f ggml-cpu/arch/wasm/quants.c ]; then
        echo "Error: pinned GGML tree is missing its wasm quant kernels." >&2
        exit 1
    fi
    echo "SIMD: wasm32 - using GGML's wasm SIMD128 quant kernels"
    GENERIC_DEFS=""
    ARCH_OBJECTS="ggml-cpu/arch/wasm/quants.o"
    ARCH_FLAGS="-msimd128"
    DISPATCH_OBJECTS=""
    ARCH_KERNELS_DEF="-DRGGML_ARCH_WASM=1"
    SIMD_DISPATCH_DEF=""
fi
if [ -z "$SIMD_EXTRA_OBJECTS" ] && [ -z "$ARCH_OBJECTS" ]; then
    echo "SIMD: no staged variant for this toolchain - using portable quant kernels"
fi
rm -f "$_probe_base" "$_probe_c" "$_probe_macros" "${_probe_c}.out"

# --- Does R's BLAS actually provide single precision? -------------------------
# GGML's BLAS backend calls cblas_sgemm; our shim (rggml_cblas.c) implements it
# over the Fortran BLAS. But R only guarantees the DOUBLE routines: <R_ext/BLAS.h>
# declares no single-precision entry points, and Windows' Rblas.dll exports no
# sgemm_ at all. Most Linux reference BLAS builds do, which is why this went
# unnoticed until the first Windows build failed to link. Probe, and let the shim
# promote to dgemm_ when sgemm_ is missing.
CBLAS_DEFS=""
BLAS_ENABLED=1
if [ "$IS_WASM" = "1" ]; then
    # webR's flang BLAS uses hidden character-length arguments. Our native
    # C-to-Fortran shim follows R's host ABI and cannot be linked to that wasm
    # ABI. GGML's CPU backend already owns dense products on this target.
    BLAS_ENABLED=0
    echo "BLAS: disabled for wasm - using GGML's CPU backend"
elif [ -z "${RGGML_NO_SGEMM:-}" ]; then
    _bl=`"${R_HOME}/bin/R" CMD config BLAS_LIBS 2>/dev/null`
    _fl=`"${R_HOME}/bin/R" CMD config FLIBS 2>/dev/null`
    _sg=`mktemp 2>/dev/null || echo "/tmp/rggml_sgemm_$$"`
    cat > "${_sg}.c" <<'SGEOF'
extern void sgemm_(const char *, const char *, const int *, const int *, const int *,
                   const float *, const float *, const int *, const float *, const int *,
                   const float *, float *, const int *);
int main(void) {
    int n = 1; float a = 0, b = 0, c = 0, al = 1, be = 0;
    sgemm_("N", "N", &n, &n, &n, &al, &a, &n, &b, &n, &be, &c, &n);
    return 0;
}
SGEOF
    if $CC "${_sg}.c" -o "${_sg}.out" $_bl $_fl >/dev/null 2>&1; then
        echo "BLAS: sgemm_ available - GGML's BLAS backend uses it directly"
        CBLAS_DEFS="-DRGGML_HAVE_SGEMM"
    else
        echo "BLAS: no sgemm_ in R's BLAS - promoting to dgemm_ in the cblas shim"
    fi
    rm -f "$_sg" "${_sg}.c" "${_sg}.out"
else
    echo "BLAS: RGGML_NO_SGEMM set - forcing the dgemm_ promotion path"
fi

# --- Vulkan backend (only when requested; see the note at the top) ------------
# Mirrors upstream GGML's shader recipe: probe glslc's optional shader
# features, build the shader generator, and compile every .comp into an
# embedded SPIR-V translation unit. The generated tree is a build artifact
# cleaned by ./cleanup, never vendored.
VULKAN_OBJECTS=""
VULKAN_CPPFLAGS=""
VULKAN_LIBS=""
if [ "$USE_VULKAN" = "1" ]; then
    echo "Vulkan: requested (--with-vulkan / RGGML_VULKAN=1)"

    # glslc: $GLSLC, then the Vulkan SDK, then PATH.
    if [ -n "${GLSLC:-}" ] && [ -x "$GLSLC" ]; then
        :
    elif [ -n "${VULKAN_SDK:-}" ] && [ -x "$VULKAN_SDK/Bin/glslc.exe" ]; then
        GLSLC="$VULKAN_SDK/Bin/glslc.exe"          # Windows SDK layout
    elif [ -n "${VULKAN_SDK:-}" ] && [ -x "$VULKAN_SDK/bin/glslc" ]; then
        GLSLC="$VULKAN_SDK/bin/glslc"
    else
        GLSLC=`command -v glslc 2>/dev/null || command -v glslc.exe 2>/dev/null || true`
    fi

    HAVE_VULKAN_H="no"
    if [ "$IS_WIN" = "1" ] && [ -n "${VULKAN_SDK:-}" ] && [ -f "${VULKAN_SDK}/Include/vulkan/vulkan.h" ]; then
        HAVE_VULKAN_H="yes"
    elif [ -f "/usr/include/vulkan/vulkan.h" ] || [ -n "${VULKAN_SDK:-}" ]; then
        HAVE_VULKAN_H="yes"
    elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists vulkan 2>/dev/null; then
        HAVE_VULKAN_H="yes"
    fi

    if [ -z "$GLSLC" ] || [ "$HAVE_VULKAN_H" = "no" ]; then
        echo "Error: Vulkan was requested but its build dependencies are missing." >&2
        [ -z "$GLSLC" ] && echo "  missing: glslc (shader compiler)" >&2
        [ "$HAVE_VULKAN_H" = "no" ] && echo "  missing: vulkan/vulkan.h (Vulkan headers)" >&2
        echo "  Debian/Ubuntu: apt-get install libvulkan-dev glslc" >&2
        echo "  Otherwise install the LunarG Vulkan SDK and export VULKAN_SDK." >&2
        exit 1
    fi
    echo "Vulkan: glslc = $GLSLC"

    if [ "$IS_WIN" = "1" ]; then
        # The loader library is vulkan-1, not vulkan, and the SDK uses Include/Lib.
        VULKAN_CPPFLAGS="-I${VULKAN_SDK}/Include"
        VULKAN_LIBS="-L${VULKAN_SDK}/Lib -lvulkan-1"
    elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists vulkan 2>/dev/null; then
        VULKAN_CPPFLAGS=`pkg-config --cflags vulkan`
        VULKAN_LIBS=`pkg-config --libs vulkan`
    else
        VULKAN_LIBS="-lvulkan"
        if [ -n "${VULKAN_SDK:-}" ]; then
            VULKAN_CPPFLAGS="-I${VULKAN_SDK}/include"
            VULKAN_LIBS="-L${VULKAN_SDK}/lib $VULKAN_LIBS"
        fi
    fi

    # Which optional shader features does *this* glslc understand? The generated
    # shader set depends on the answer, so the same defines must reach both the
    # generator and every compiled TU.
    SHADERGEN_DEFINES=""
    for _feat in coopmat coopmat2 integer_dot bfloat16; do
        _test="ggml-vulkan/vulkan-shaders/feature-tests/${_feat}.comp"
        if [ -f "$_test" ] && "$GLSLC" --target-env=vulkan1.2 -o /dev/null "$_test" >/dev/null 2>&1; then
            echo "Vulkan: glslc supports $_feat"
            _up=`echo "$_feat" | tr 'a-z' 'A-Z'`
            SHADERGEN_DEFINES="$SHADERGEN_DEFINES -DGGML_VULKAN_${_up}_GLSLC_SUPPORT"
        fi
    done

    ( cd ggml-vulkan/vulkan-shaders
      echo "Vulkan: building shader generator"
      $CXX -std=c++17 -O2 $SHADERGEN_DEFINES -o vulkan-shaders-gen vulkan-shaders-gen.cpp -pthread

      # Always regenerate from scratch: the shader set depends on glslc's
      # feature support, and a partial overwrite leaves orphan .cpp whose
      # symbols the regenerated header no longer declares (undefined symbols
      # at link time).
      rm -rf ../generated
      mkdir -p ../generated/spv
      ./vulkan-shaders-gen --output-dir ../generated/spv \
                           --target-hpp ../generated/ggml-vulkan-shaders.hpp
      echo "Vulkan: compiling shaders (this takes a minute)"
      for _shader in *.comp; do
          ./vulkan-shaders-gen --glslc "$GLSLC" --source "`pwd`/$_shader" \
              --output-dir ../generated/spv \
              --target-hpp ../generated/ggml-vulkan-shaders.hpp \
              --target-cpp "../generated/${_shader}.cpp"
      done
    )

    # Upstream's ggml-vulkan.cpp is the backend translation unit. Each generated
    # shader array is kept in its own translation unit to bound compiler memory.
    VULKAN_OBJECTS="ggml-vulkan/ggml-vulkan.o"
    for _cpp in ggml-vulkan/generated/*.cpp; do
        VULKAN_OBJECTS="$VULKAN_OBJECTS ${_cpp%.cpp}.o"
    done
    VULKAN_CPPFLAGS="$VULKAN_CPPFLAGS -DGGML_USE_VULKAN -Iggml-vulkan -Iggml-vulkan/generated $SHADERGEN_DEFINES"
    echo "Vulkan: enabled (`ls ggml-vulkan/generated/*.cpp | wc -l` shader TUs)"
else
    echo "Vulkan: disabled (build with --with-vulkan to enable the GPU backend)"
fi

# --- CUDA backend (only when requested) ---------------------------------------
# CUDA comes from the same pinned upstream GGML source tree as the core.
# The default build never looks for nvcc. An explicit CUDA build is native to
# its installation machine unless RGGML_CUDA_ARCH names another architecture,
# for example sm_89 or sm_120a. This keeps GPU switches out of R's recorded
# package flags.
CUDA_CPPFLAGS=""
CUDA_NVCCFLAGS=""
CUDA_LIBS=""
NVCC=""
if [ "$USE_CUDA" = "1" ]; then
    echo "CUDA: requested (--with-cuda / RGGML_CUDA=1)"
    if [ "$IS_WIN" = "1" ]; then
        echo "Error: the opt-in CUDA recipe currently targets Unix-like R builds." >&2
        exit 1
    fi

    if [ -n "$CUDA_HOME_REQUEST" ] && [ -x "$CUDA_HOME_REQUEST/bin/nvcc" ]; then
        CUDA_HOME=$CUDA_HOME_REQUEST
        NVCC="$CUDA_HOME/bin/nvcc"
    else
        NVCC=`command -v nvcc 2>/dev/null || true`
        if [ -n "$NVCC" ]; then
            CUDA_HOME=`cd "\`dirname "$NVCC"\`/.." && pwd`
        fi
    fi
    if [ -z "$NVCC" ] || [ ! -x "$NVCC" ]; then
        echo "Error: CUDA was requested but nvcc was not found." >&2
        echo "  Set CUDA_HOME or use --with-cuda=/path/to/cuda." >&2
        exit 1
    fi
    if [ ! -f "$CUDA_HOME/include/cuda_runtime.h" ]; then
        echo "Error: $CUDA_HOME/include/cuda_runtime.h not found." >&2
        exit 1
    fi

    CUDA_ARCH_REQUEST=${RGGML_CUDA_ARCH:-native}
    CUDA_GRAPHS=${RGGML_CUDA_GRAPHS:-0}
    case "$CUDA_GRAPHS" in
        0|1) ;;
        *)
            echo "Error: RGGML_CUDA_GRAPHS must be 0 or 1." >&2
            exit 1
            ;;
    esac
    case "$CUDA_ARCH_REQUEST" in
        *[!A-Za-z0-9_-]*)
            echo "Error: invalid RGGML_CUDA_ARCH '$CUDA_ARCH_REQUEST'." >&2
            exit 1
            ;;
    esac

    _cu=`mktemp 2>/dev/null || echo "/tmp/rggml_cuda_probe_$$"`
    _cu_src="${_cu}.cu"
    CUDA_ARCH=$CUDA_ARCH_REQUEST
    if [ "$CUDA_ARCH" = "native" ]; then
        cat > "$_cu_src" <<'EOF'
#include <stdio.h>
#include <cuda_runtime.h>
int main(void) {
    int device;
    struct cudaDeviceProp prop;
    if (cudaGetDevice(&device) != cudaSuccess ||
        cudaGetDeviceProperties(&prop, device) != cudaSuccess) return 1;
    printf("%d%d\n", prop.major, prop.minor);
    return 0;
}
EOF
        if ! "$NVCC" -std=c++17 "$_cu_src" -o "${_cu}.exe" >/dev/null 2>&1; then
            rm -f "$_cu" "$_cu_src" "${_cu}.exe"
            echo "Error: nvcc could not build the native-architecture probe." >&2
            exit 1
        fi
        _cuda_cap=`"${_cu}.exe" 2>/dev/null || true`
        case "$_cuda_cap" in
            ''|*[!0-9]*)
                rm -f "$_cu" "$_cu_src" "${_cu}.exe"
                echo "Error: no CUDA device is available for the native build." >&2
                echo "  Set RGGML_CUDA_ARCH explicitly when cross-compiling." >&2
                exit 1
                ;;
        esac
        CUDA_ARCH="sm_${_cuda_cap}"
    fi

    # CUDA 12.x architecture-specific FP4 instructions require the `a` target.
    # Upstream GGML's CMake recipe makes the same 12X -> 12Xa conversion until
    # a later GPU family gives plain 12X different forward-compatibility value.
    case "$CUDA_ARCH" in
        sm_12[0-9]|compute_12[0-9]) CUDA_ARCH="${CUDA_ARCH}a" ;;
    esac
    case "$CUDA_ARCH" in
        sm_*a|sm_*f)
            _cuda_code=${CUDA_ARCH#sm_}
            CUDA_ARCH_FLAGS="-gencode=arch=compute_${_cuda_code},code=compute_${_cuda_code} -gencode=arch=compute_${_cuda_code},code=sm_${_cuda_code}"
            ;;
        compute_*a|compute_*f)
            _cuda_code=${CUDA_ARCH#compute_}
            CUDA_ARCH_FLAGS="-gencode=arch=compute_${_cuda_code},code=compute_${_cuda_code}"
            ;;
        *) CUDA_ARCH_FLAGS="-arch=$CUDA_ARCH" ;;
    esac
    CUDA_NVCCFLAGS="-O3 -DNDEBUG -std=c++17 --use_fast_math --extended-lambda $CUDA_ARCH_FLAGS"
    echo "CUDA: nvcc = $NVCC"
    echo "CUDA: architecture = $CUDA_ARCH (requested $CUDA_ARCH_REQUEST)"

    printf '__global__ void k(void) {}\nint main(void) { k<<<1,1>>>(); return 0; }\n' > "$_cu_src"
    if ! "$NVCC" $CUDA_NVCCFLAGS -c "$_cu_src" -o "${_cu}.o" >/dev/null 2>&1; then
        rm -f "$_cu" "$_cu_src" "${_cu}.exe" "${_cu}.o"
        echo "Error: nvcc cannot compile for CUDA architecture '$CUDA_ARCH'." >&2
        exit 1
    fi
    if "$NVCC" $CUDA_NVCCFLAGS -compress-mode=size -c "$_cu_src" \
            -o "${_cu}.compressed.o" >/dev/null 2>&1; then
        CUDA_NVCCFLAGS="$CUDA_NVCCFLAGS -compress-mode=size"
    fi
    rm -f "$_cu" "$_cu_src" "${_cu}.exe" "${_cu}.o" "${_cu}.compressed.o"

    CUDA_LIBDIR=""
    for _lib in "$CUDA_HOME/lib64" \
                "$CUDA_HOME/targets/`uname -m`-linux/lib" \
                "$CUDA_HOME/targets/x86_64-linux/lib" \
                "$CUDA_HOME/targets/sbsa-linux/lib"; do
        if [ -f "$_lib/libcudart.so" ] && [ -f "$_lib/libcublas.so" ]; then
            CUDA_LIBDIR=$_lib
            break
        fi
    done
    if [ -z "$CUDA_LIBDIR" ]; then
        echo "Error: CUDA runtime and cuBLAS libraries not found under $CUDA_HOME." >&2
        exit 1
    fi
    CUDA_STUBDIR=""
    for _stub in "$CUDA_HOME/targets/`uname -m`-linux/lib/stubs" \
                 "$CUDA_HOME/targets/x86_64-linux/lib/stubs" \
                 "$CUDA_HOME/targets/sbsa-linux/lib/stubs"; do
        if [ -f "$_stub/libcuda.so" ]; then
            CUDA_STUBDIR=$_stub
            break
        fi
    done

    CUDA_CPPFLAGS="-DGGML_USE_CUDA -I$CUDA_HOME/include"
    if [ "$CUDA_GRAPHS" = "1" ]; then
        CUDA_CPPFLAGS="$CUDA_CPPFLAGS -DGGML_CUDA_USE_GRAPHS"
        echo "CUDA: graph capture enabled (RGGML_CUDA_GRAPHS=0 disables it)"
    else
        echo "CUDA: graph capture disabled (RGGML_CUDA_GRAPHS=1 enables it)"
    fi
    CUDA_LIBS="-L$CUDA_LIBDIR -Wl,-rpath,$CUDA_LIBDIR -lcudart -lcublas -lcublasLt"
    if [ -n "$CUDA_STUBDIR" ]; then
        CUDA_LIBS="$CUDA_LIBS -L$CUDA_STUBDIR -lcuda"
    else
        CUDA_LIBS="$CUDA_LIBS -lcuda"
    fi
    echo "CUDA: enabled (libraries in $CUDA_LIBDIR)"
else
    echo "CUDA: disabled (build with --with-cuda to enable the NVIDIA backend)"
fi

make clean >/dev/null 2>&1 || true
if make SIMD_EXTRA_OBJECTS="$SIMD_EXTRA_OBJECTS" SIMD_DISPATCH_DEFS="$SIMD_DISPATCH_DEFS" \
        GENERIC_DEFS="$GENERIC_DEFS" ARCH_OBJECTS="$ARCH_OBJECTS" \
        ARCH_FLAGS="$ARCH_FLAGS" DISPATCH_OBJECTS="$DISPATCH_OBJECTS" \
        BLAS_ENABLED="$BLAS_ENABLED" CBLAS_DEFS="$CBLAS_DEFS" \
        VULKAN_OBJECTS="$VULKAN_OBJECTS" VULKAN_CPPFLAGS="$VULKAN_CPPFLAGS" \
        CUDA_ENABLED="$USE_CUDA" NVCC="$NVCC" CUDA_CPPFLAGS="$CUDA_CPPFLAGS" \
        CUDA_NVCCFLAGS="$CUDA_NVCCFLAGS" CUDA_HOST_PIC="$R_CPICFLAGS"; then
    echo "libggml.a built successfully"
else
    echo "Error: failed to build libggml.a"
    exit 1
fi

if [ ! -f "libggml.a" ]; then
    echo "Error: libggml.a was not created"
    exit 1
fi

# Remove intermediate object files from the source tree (keep the archive).
find . -name '*.o' -delete

cd ../..

# Windows has no libdl (dlopen lives in the C runtime), and R picks up
# src/Makevars.win rather than src/Makevars there.
if [ "$IS_WIN" = "1" ]; then
    MAKEVARS_FILE="src/Makevars.win"
    PLATFORM_LIBS="-lpthread -lm"
else
    MAKEVARS_FILE="src/Makevars"
    PLATFORM_LIBS="-lpthread -ldl -lm"
fi

echo "Creating $MAKEVARS_FILE..."
mkdir -p src
cat > "$MAKEVARS_FILE" << 'EOF'
# Generated by configure - do not edit by hand.
#
# Rggml's own src/ files (rggml_api.c, rggml_init.c, rggml_test.c) are
# plain C; all C++ is inside the vendored static library (inst/ggml/,
# built above with its own flags). CXX_STD is still needed here (with no
# PKG_CXXFLAGS, since there is nothing to compile as C++) so that R links
# the final shared object with the C++ compiler/runtime - required because
# libggml.a itself contains C++ object code (std::filesystem, exceptions,
# etc. from ggml-backend*.cpp).

PKG_CPPFLAGS = -I../inst/include -I../inst/ggml @RGGML_VULKAN_DEF@ @RGGML_CUDA_DEF@ @RGGML_BUILD_DEFS@
# @BLAS_LINK_LIBS@ resolves the Fortran sgemm_ that our cblas shim
# (inst/ggml/rggml_cblas.c) forwards GGML's BLAS backend to. -lggml precedes
# it so its unresolved sgemm_ pulls from R's BLAS. It is empty on wasm, where
# no BLAS backend or Fortran shim is compiled. @VULKAN_LIBS@ is empty unless
# configure was given --with-vulkan. @CUDA_LIBS@ is similarly empty unless
# configure was given --with-cuda.
PKG_LIBS = -L../inst/ggml -lggml @VULKAN_LIBS@ @CUDA_LIBS@ @BLAS_LINK_LIBS@ @PLATFORM_LIBS@

CXX_STD = CXX17
EOF

# Substituted here rather than expanded in the heredoc above, which is quoted so
# that make's own $(BLAS_LIBS)/$(FLIBS) survive verbatim when enabled.
RGGML_VULKAN_DEF=""
[ "$USE_VULKAN" = "1" ] && RGGML_VULKAN_DEF="-DRGGML_HAVE_VULKAN"
RGGML_CUDA_DEF=""
[ "$USE_CUDA" = "1" ] && RGGML_CUDA_DEF="-DRGGML_HAVE_CUDA"
# The three build decisions above, carried into the binary so rggml_cpu_info()
# reports what was actually compiled rather than what we meant to compile.
RGGML_BUILD_DEFS="$ARCH_KERNELS_DEF $SIMD_DISPATCH_DEF $CBLAS_DEFS"
BLAS_LINK_LIBS=""
if [ "$BLAS_ENABLED" = "1" ]; then
    RGGML_BUILD_DEFS="$RGGML_BUILD_DEFS -DRGGML_HAVE_BLAS"
    BLAS_LINK_LIBS='$(BLAS_LIBS) $(FLIBS)'
fi
sed -i.bak -e "s|@VULKAN_LIBS@|$VULKAN_LIBS|" \
           -e "s|@CUDA_LIBS@|$CUDA_LIBS|" \
           -e "s|@BLAS_LINK_LIBS@|$BLAS_LINK_LIBS|" \
           -e "s|@RGGML_VULKAN_DEF@|$RGGML_VULKAN_DEF|" \
           -e "s|@RGGML_CUDA_DEF@|$RGGML_CUDA_DEF|" \
           -e "s|@RGGML_BUILD_DEFS@|$RGGML_BUILD_DEFS|" \
           -e "s|@PLATFORM_LIBS@|$PLATFORM_LIBS|" "$MAKEVARS_FILE" && rm -f "${MAKEVARS_FILE}.bak"

# Drop stale objects from a previous configure. make compares timestamps, not
# flags, so a src/*.o built before (say) --with-vulkan was added would survive
# the flag change and silently produce a shared object that disagrees with the
# src/Makevars we just wrote - e.g. Rggml_backend_vulkan_device_count compiled
# from its no-Vulkan branch, reporting zero devices in a Vulkan-enabled build.
rm -f src/*.o src/*.so src/*.dll

echo "Configure completed successfully."
echo "Created $MAKEVARS_FILE linking against inst/ggml/libggml.a."
