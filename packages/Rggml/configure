#!/bin/sh
# Configure script for the Rggml R package.
#
# Builds the vendored GGML CPU backend (inst/ggml/) into a static library
# using R's own toolchain settings, then writes src/Makevars so that the
# package shared object links against it. Mirrors the approach used by
# Rfmalloc's configure (inst/fmalloc/libfmalloc.a) and Rgguf.

set -e

echo "Configuring Rggml..."

if [ ! -d "inst/ggml" ]; then
    echo "Error: vendored GGML source not found in inst/ggml"
    exit 1
fi

R_HOME=${R_HOME:-$(R RHOME)}
if [ -z "$R_HOME" ]; then
    echo "Error: R_HOME not found. Please install R."
    exit 1
fi
echo "R_HOME: $R_HOME"

CC=`"${R_HOME}/bin/R" CMD config CC`
CXX=`"${R_HOME}/bin/R" CMD config CXX17`
if [ -z "$CXX" ] || [ "$CXX" = "" ]; then
    CXX=`"${R_HOME}/bin/R" CMD config CXX`
fi
AR=`"${R_HOME}/bin/R" CMD config AR`
RANLIB=`"${R_HOME}/bin/R" CMD config RANLIB`
R_CPPFLAGS=`"${R_HOME}/bin/R" CMD config CPPFLAGS`
R_CFLAGS=`"${R_HOME}/bin/R" CMD config CFLAGS`
R_CXXFLAGS=`"${R_HOME}/bin/R" CMD config CXX17FLAGS`
if [ -z "$R_CXXFLAGS" ]; then
    R_CXXFLAGS=`"${R_HOME}/bin/R" CMD config CXXFLAGS`
fi
R_CPICFLAGS=`"${R_HOME}/bin/R" CMD config CPICFLAGS`
R_INCLUDE_FLAGS=`"${R_HOME}/bin/R" CMD config --cppflags`

# AR/RANLIB sometimes come back as "R" (conflicts with the R executable).
case "$AR" in
    "R") AR="ar" ;;
esac
case "$RANLIB" in
    "R") RANLIB="ranlib" ;;
esac

echo "CC: $CC"
echo "CXX: $CXX"
echo "AR: $AR"
echo "RANLIB: $RANLIB"

echo "Building vendored GGML CPU backend (libggml.a)..."
cd inst/ggml || exit 1

export CC CXX AR RANLIB
export CFLAGS="$R_CFLAGS $R_CPICFLAGS"
export CXXFLAGS="$R_CXXFLAGS $R_CPICFLAGS"
export CPPFLAGS="$R_CPPFLAGS"
# Only rggml_io.c needs R's own headers (R.h/Rinternals.h); it is compiled
# with R_GGML_IO_IMPL, which the Makefile pairs with this extra include path.
export R_INCLUDE_FLAGS

# --- Probe runtime-dispatched SIMD variants (RsimdDispatch strategy) ---------
# Per-ISA kernels are compiled here with their own ISA flags, NOT through R's
# recorded package compilation, so R CMD check raises no non-portable-flags
# NOTE. A variant is only linked (and, after a runtime CPUID check, only ever
# called) when the toolchain accepts its flags - so e.g. -mavx2 is skipped on
# arm64/macOS, which then falls back to GGML's scalar reference.
SIMD_EXTRA_OBJECTS=""
SIMD_DISPATCH_DEFS=""
_probe_base=`mktemp 2>/dev/null || echo "/tmp/rggml_probe_$$"`
_probe_c="${_probe_base}.c"
printf 'int main(void){return 0;}\n' > "$_probe_c"
# x86 (incl. Intel macOS, still a CRAN/r-universe target): stage the AVX2
# variant if the toolchain accepts the flags; a runtime CPUID check gates it.
if $CC -mavx2 -mfma "$_probe_c" -o "${_probe_c}.out" >/dev/null 2>&1; then
    echo "SIMD: AVX2 supported - staging AVX2 q4_K kernel variant"
    SIMD_EXTRA_OBJECTS="$SIMD_EXTRA_OBJECTS rggml_q4k_avx2.o"
    SIMD_DISPATCH_DEFS="$SIMD_DISPATCH_DEFS -DRGGML_HAVE_AVX2"
fi
# aarch64 (Apple Silicon macOS, ARM Linux/Graviton, Windows-on-ARM): NEON is a
# mandatory baseline, so stage a -O3 NEON variant whenever the target is
# aarch64 (no ISA flag or CPUID gate is needed for NEON there).
if $CC -dM -E -x c "$_probe_c" 2>/dev/null | grep -q '__aarch64__\|_M_ARM64'; then
    echo "SIMD: aarch64 (NEON baseline) - staging NEON q4_K kernel variant"
    SIMD_EXTRA_OBJECTS="$SIMD_EXTRA_OBJECTS rggml_q4k_neon.o"
    SIMD_DISPATCH_DEFS="$SIMD_DISPATCH_DEFS -DRGGML_HAVE_NEON"
fi
if [ -z "$SIMD_EXTRA_OBJECTS" ]; then
    echo "SIMD: no staged variant for this toolchain - q4_K uses the scalar reference"
fi
rm -f "$_probe_base" "$_probe_c" "${_probe_c}.out"

make clean >/dev/null 2>&1 || true
if make SIMD_EXTRA_OBJECTS="$SIMD_EXTRA_OBJECTS" SIMD_DISPATCH_DEFS="$SIMD_DISPATCH_DEFS"; then
    echo "libggml.a built successfully"
else
    echo "Error: failed to build libggml.a"
    exit 1
fi

if [ ! -f "libggml.a" ]; then
    echo "Error: libggml.a was not created"
    exit 1
fi

# Remove intermediate object files from the source tree (keep the archive).
find . -name '*.o' -delete

cd ../..

echo "Creating src/Makevars..."
mkdir -p src
cat > src/Makevars << 'EOF'
# Generated by configure - do not edit by hand.
#
# Rggml's own src/ files (rggml_api.c, rggml_init.c, rggml_test.c) are
# plain C; all C++ is inside the vendored static library (inst/ggml/,
# built above with its own flags). CXX_STD is still needed here (with no
# PKG_CXXFLAGS, since there is nothing to compile as C++) so that R links
# the final shared object with the C++ compiler/runtime - required because
# libggml.a itself contains C++ object code (std::filesystem, exceptions,
# etc. from ggml-backend*.cpp).

PKG_CPPFLAGS = -I../inst/include
# $(BLAS_LIBS) $(FLIBS) resolve the Fortran sgemm_ that our cblas shim
# (inst/ggml/rggml_cblas.c) forwards GGML's BLAS backend to. -lggml precedes
# them so its unresolved sgemm_ pulls from R's BLAS.
PKG_LIBS = -L../inst/ggml -lggml $(BLAS_LIBS) $(FLIBS) -lpthread -ldl -lm

CXX_STD = CXX17
EOF

echo "Configure completed successfully."
echo "Created src/Makevars linking against inst/ggml/libggml.a."
