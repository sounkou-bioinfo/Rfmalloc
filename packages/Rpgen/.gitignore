# R build/check artifacts
/*.tar.gz
/*.Rcheck/
.Rproj.user
.Rhistory
.RData
.Ruserdata

# compiled package objects
src/*.o
src/*.dll
src/*.so
src/symbols.rds
src/Makevars

# Unlike Rggml (configure.win generates src/Makevars.win), Rpgen's
# src/Makevars.win is vendored *source*, used by R as-is on Windows with no
# substitution step - un-ignore it against the root .gitignore's blanket
# 'packages/*/src/Makevars.win' rule (aimed at the generated case).
!src/Makevars.win

# vendored pgenlib build artifacts (generated by configure/Makevars at
# install time, not part of the vendoring recipe's committed output)
tools/include/**/*.o
src/libPLINK2.a
src/libPGZSTD.a
src/libPGDEFLATE.a

# autoconf
config.log
config.status
autom4te.cache/

# pkgdown
docs/
